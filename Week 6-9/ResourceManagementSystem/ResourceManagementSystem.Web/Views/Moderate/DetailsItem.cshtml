@model ResourceManagementSystem.Application.ViewModel.Items.ItemVM

@{
    ViewData["Title"] = "DetailsItem";
}

<h1>Details Item</h1>

<div>
    <hr />
    <img src="@Model.ImagePath"/>
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Id)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Id)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        @if(User.IsInRole("Admin"))
        {
            <dt class = "col-sm-2">
                @Html.DisplayNameFor(model => model.ImagePath)
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.ImagePath)
            </dd>
        }
    </dl>
</div>

<div class="card">
    Serials
    @for (int i = 0; i < Model.SerialsList?.Count; i++)
    {
        <div>
            <input asp-for="SerialsList[i].Id" type="hidden" />
            <input asp-for="SerialsList[i].Name" type="hidden" />
            <input asp-for="SerialsList[i].Status" type="hidden" />
            @Model.SerialsList[i].Name
        </div>
    }
</div>
<div class="card">
    Departments
    @for (int i = 0; i < Model.DepartmentsList?.Count; i++)
    {
        @if(Model.DepartmentsList[i].Status)
        {
        <div>
            <input asp-for="DepartmentsList[i].Id" type="hidden" />
            <input asp-for="DepartmentsList[i].Name" type="hidden" />
            <input asp-for="DepartmentsList[i].Status" type="hidden" />
            @Model.DepartmentsList[i].Name
        </div>
        }
    }
</div>

<div>
    @Html.ActionLink("Edit", "EditItem", new { id = Model.Id }) |
    @Html.ActionLink("Delete", "DeleteItem", new { id = Model.Id }) |
    <a asp-action="Resources">Back to List</a>
</div>
