@model ResourceManagementSystem.Application.ViewModel.Users.DetailsEditUserVM

@{
    ViewData["Title"] = "DetailsUser";
}

<h1>Details User</h1>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Id)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Id)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FullName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FullName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.UserName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.UserName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Email)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Phone)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Phone)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
    </dl>
</div>
<div>
    <div>
        Roles
        @for (int i = 0; i < Model.RolesList?.Count; i++)
        {
            <div>
                <input asp-for="RolesList[i].Id" type="hidden" />
                <input asp-for="RolesList[i].Name" type="hidden" />
                <input asp-for="RolesList[i].Status" type="hidden" />
                @Model.RolesList[i].Name
            </div>
        }
    </div>
    <div>
        Departments
        @for (int i = 0; i < Model.DepartmentsList?.Count; i++)
        {
            <div>
                <input asp-for="DepartmentsList[i].Id" type="hidden" />
                <input asp-for="DepartmentsList[i].Name" type="hidden" />
                <input asp-for="DepartmentsList[i].Status" type="hidden" />
                @Model.DepartmentsList[i].Name
            </div>
        }
    </div>
    <div>
        Item Reservation
        @for (int i = 0; i < Model.ReservationItemList?.Count; i++)
        {
            <div>
                <input asp-for="ReservationItemList[i].Id" type="hidden" />
                <input asp-for="ReservationItemList[i].Name" type="hidden" />
                <input asp-for="ReservationItemList[i].Status" type="hidden" />
                @Model.ReservationItemList[i].Name
            </div>
        }
    </div>
</div>

<div>
    @Html.ActionLink("Edit", "EditUser", new { id = Model.Id }) |
    <a asp-action="Users">Back to List</a>
</div>
