@model ResourceManagementSystem.Application.ViewModel.Departments.DetailsEditDepartmentVM

@{
    ViewData["Title"] = "DetailsDepartment";
}

<h1>Details Department</h1>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Id)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Id)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
    </dl>
</div>
<div>
    Users
    <div>
        #@foreach (var user in Model.UsersList)
        {
        <span>@user.Id - @user.Name</span><br>
        }
    </div>
</div>
<div>
    Items
    <div>
        #@foreach (var item in Model.UsersList)
        {
            <span>@item.Name</span><br>
        }
    </div>
</div>
<div>
    @Html.ActionLink("Edit", "EditDepartment", new { id = Model.Id }) |
    <a asp-action="Index">Back to List</a>
</div>
