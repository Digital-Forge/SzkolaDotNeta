@model IEnumerable<ResourceManagementSystem.Application.ViewModel.Departments.DepartmentOfListVM>

@{
    ViewData["Title"] = "Departments";
}

<h1>Departments</h1>

<p>
    <a asp-action="CreateDepartment">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CountOfUsers)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CountOfItems)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CountOfUsers)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CountOfItems)
            </td>
            <td>
                @Html.ActionLink("Details", "DetailsDepartment", new { id = item.Id })
                @Html.ActionLink("Add/Remove Users", "AddRemoveUsersToDepartment", new { id = Model.Id }) |
            </td>
        </tr>
}
    </tbody>
</table>
